  "dependencies": {
    "@google/genai": "^1.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serve": "^14.2.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "dotenv": "^16.4.5",
    "esbuild": "^0.20.2"
  }
}