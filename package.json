{
  "name": "ordemilk-tech-assist",
  "version": "1.0.0",
  "description": "Assistente técnico especializado para resfriadores de leite Ordemilk.",
  "main": "dist/index.js",
  "scripts": {
    "build": "node esbuild.config.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
